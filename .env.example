# ============================================================
# TrackIt — root environment template
# Copy to .env and fill in the values. NEVER commit .env.
# ============================================================

# --- Backend (FastAPI) ---
# Postgres connection used by the backend container. Inside docker-compose the
# host is `db`; from your host machine use `localhost` instead.
DATABASE_URL=postgresql+asyncpg://trackit:trackit_dev@db:5432/trackit

# JWT signing key. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# Fernet symmetric key used to encrypt OAuth tokens at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# JWT lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Google OAuth (Gmail API) ---
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Externally-visible URL of the backend. Must match the redirect URIs you
# register in Google Cloud Console (`{API_BASE_URL}/auth/google/callback`
# and `{API_BASE_URL}/gmail/callback`).
API_BASE_URL=http://localhost:8000

# Custom scheme used by the mobile app for deep-linking after OAuth callbacks
# (must match `expo.scheme` in mobile/app.json).
MOBILE_RETURN_SCHEME=trackit

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- CORS / Logging ---
CORS_ORIGINS=*
LOG_LEVEL=INFO

# --- Mobile (Expo) ---
# These are exposed to the JS bundle (EXPO_PUBLIC_ prefix is required).
EXPO_PUBLIC_API_URL=http://localhost:8000
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=
