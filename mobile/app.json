{
  "expo": {
    "name": "TrackIt",
    "slug": "trackit",
    "scheme": "trackit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E0F12"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.trackit.app"
    },
    "android": {
      "package": "com.trackit.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0E0F12"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser"
    ],
    "extra": {
      "apiUrl": "https://9911-2800-484-5e83-a00-9500-eb1d-bdbc-823.ngrok-free.app"
    }
  }
}
